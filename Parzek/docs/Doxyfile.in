PROJECT_NAME           = "Parzek"
PROJECT_BRIEF          = "Parzek API and manual reference"
OUTPUT_DIRECTORY       = @CMAKE_CURRENT_BINARY_DIR@/doxygen
INPUT                  = @CMAKE_CURRENT_SOURCE_DIR@/frontpage.md @CMAKE_CURRENT_SOURCE_DIR@/../Parzek.hpp @CMAKE_CURRENT_SOURCE_DIR@/../Parzek.cpp @CMAKE_CURRENT_SOURCE_DIR@/../main.cpp @CMAKE_CURRENT_SOURCE_DIR@/manual
RECURSIVE              = YES
FILE_PATTERNS          = *.hpp *.h *.cpp *.md
USE_MDFILE_AS_MAINPAGE = @CMAKE_CURRENT_SOURCE_DIR@/frontpage.md
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = YES
LATEX_OUTPUT           = latex
GENERATE_XML           = YES
XML_OUTPUT             = xml
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
JAVADOC_AUTOBRIEF      = YES
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
FULL_PATH_NAMES        = NO
WARN_IF_UNDOCUMENTED   = NO
WARN_AS_ERROR          = NO
QUIET                  = YES
