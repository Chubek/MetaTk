prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/include

Name: QaMRpp
Description: A header-only implementation of Lua, with a CLI, plugins, and so on
Version: @QAMRPP_PKGCONFIG_VERSION@

Libs: -L${libdir}
Cflags: -I${includedir}
