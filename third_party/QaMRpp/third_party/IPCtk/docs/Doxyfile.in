PROJECT_NAME           = IPCtk
PROJECT_NUMBER         = @PROJECT_VERSION@
OUTPUT_DIRECTORY       = @CMAKE_CURRENT_BINARY_DIR@/docs
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
RECURSIVE              = YES
INPUT                  = @CMAKE_CURRENT_SOURCE_DIR@/IPCtk.hpp @CMAKE_CURRENT_SOURCE_DIR@/DSLUtils.hpp @CMAKE_CURRENT_SOURCE_DIR@/docs
USE_MDFILE_AS_MAINPAGE = @CMAKE_CURRENT_SOURCE_DIR@/docs/FrontPage.md
FILE_PATTERNS          = *.hpp *.md
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
